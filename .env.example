# Django settings
# Set DEBUG=True only for local development — never on a server.
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-a-new-one
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite used by default in development)
# For production, set:
# DATABASE_URL=postgres://user:password@localhost:5432/horse_management

# Email settings
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Database connection lifetime (seconds). Ignored on Vercel (forced to 0 for
# serverless). 600 is a good default for always-on hosts like Railway.
CONN_MAX_AGE=600

# Uploaded media. Point at a persistent disk in production
# (e.g. Railway volume mounted at /data -> MEDIA_ROOT=/data/media).
# MEDIA_ROOT=/data/media
# Serve /media/ through Django when DEBUG=False (needed on Railway).
# SERVE_MEDIA=True

# Celery beat schedule times (Europe/London). See settings.py.
# REMINDER_HOUR=7
# REMINDER_MINUTE=0
# REMINDER_DAYS_OF_WEEK=mon-fri
# INVOICE_STATUS_HOUR=6
